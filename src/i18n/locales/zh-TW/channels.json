        "discord": {
            "description": "使用開發者门户提供的機器人令牌連線 Discord",
            "docsUrl": "https://docs.b.ai/BAIclaw",
            "fields": {
                "token": {
                    "label": "機器人令牌",
                    "placeholder": "您的 Discord 機器人令牌"
                },
                "guildId": {
                    "label": "服務器 ID",
                    "placeholder": "例如 123456789012345678",
                    "description": "限制機器人僅在特定服務器工作。右键點击服務器 → 複製服務器 ID。"
                },
                "channelId": {
                    "label": "頻道 ID (可選)",
                    "placeholder": "例如 123456789012345678",
                    "description": "限制機器人僅在特定頻道工作。右键點击頻道 → 複製頻道 ID。"
                }
            },
            "instructions": [
                "前往 Discord 開發者门户 → Applications → New Application",
                "在 Bot 部分：新增 Bot，然後複製 Bot Token",
                "在 Bot → Privileged Gateway Intents 中啟用 Message Content Intent 和 Server Members Intent",
                "在 OAuth2 → URL Generator：選擇 \"bot\" + \"applications.commands\"，新增訊息权限",
                "使用生成的 URL 邀請機器人加入您的服務器",
                "在下方貼上機器人令牌"
            ]
        },
        "whatsapp": {
            "description": "透過掃描QR Code連線 WhatsApp（無需手機號碼）",
            "docsUrl": "https://docs.b.ai/BAIclaw",
            "instructions": [
                "在手机上開啟 WhatsApp",
                "前往 設定 > 已关联裝置 >包含連線裝置",
                "掃描下方顯示的QR Code",
                "系統將自動识别您的手機號碼"
            ]
        },
        "dingtalk": {
            "description": "透過 OpenClaw 渠道插件連線钉钉（Stream 模式）",
            "docsUrl": "https://docs.b.ai/BAIclaw",
            "fields": {
                "clientId": {
                    "label": "Client ID (AppKey)",
                    "placeholder": "dingxxxxxx"
                },
                "clientSecret": {
                    "label": "Client Secret (AppSecret)",
                    "placeholder": "您的應用金鑰"
                },
                "robotCode": {
                    "label": "Robot Code（可選）",
                    "placeholder": "通常與 Client ID 相同"
                },
                "corpId": {
                    "label": "Corp ID（可選）",
                    "placeholder": "dingxxxxxx"
                },
                "agentId": {
                    "label": "Agent ID（可選）",
                    "placeholder": "123456789"
                }
            },
            "instructions": [
                "先在 OpenClaw 安裝並啟用 dingtalk 插件",
                "在钉钉開發者後台建立企业内部應用並啟用 Stream 模式",
                "填写 Client ID 和 Client Secret（必填）",
                "根据你的應用設定按需填写 Robot Code / Corp ID / Agent ID"
            ]
        },
        "signal": {
            "description": "使用 signal-cli 連線 Signal",
            "docsUrl": "https://docs.openclaw.ai/zh-CN/channels/signal",
            "fields": {
